# Supabase
SUPABASE_URL=https://my-project.supabase.co
SUPABASE_SERVICE_KEY=my-service-role-key
SUPABASE_DB_CONNECTION=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Vector Store
VECTOR_COLLECTION=safari_chunks
EMBEDDING_DIMENSION=384

# GROK
GROK_API_KEY=your-grok-key
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-2-latest

# App
CHUNK_SIZE=400
CHUNK_OVERLAP=50
TOP_K=5
LOG_LEVEL=INFO

# Security
API_KEY=your-secure-api-key-here  # Leave empty to disable auth
RATE_LIMIT_PER_MINUTE=30
MAX_QUERY_LENGTH=500
ALLOWED_ORIGINS=http://localhost:3000, i will add more origins later after deployment